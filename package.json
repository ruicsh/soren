{
  "name": "soren",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "android": "expo run:android",
    "android:clean": "expo run:android --no-build-cache",
    "android:device": "expo run:android --device",
    "android:no-build": "expo run:android --no-build",
    "format": "prettier --write .",
    "ios": "expo run:ios",
    "ios:clean": "expo run:ios --no-build-cache",
    "ios:device": "expo run:ios --device",
    "ios:no-build": "expo run:ios --no-build",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "reset-project": "node ./scripts/reset-project.js",
    "start": "expo start --dev-client",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "55.0.20",
    "expo-crypto": "55.0.14",
    "expo-dev-client": "55.0.32",
    "expo-file-system": "55.0.19",
    "expo-localization": "55.0.13",
    "expo-router": "55.0.13",
    "expo-secure-store": "55.0.13",
    "expo-speech": "55.0.13",
    "expo-speech-recognition": "3.1.3",
    "expo-splash-screen": "55.0.19",
    "lucide-react-native": "1.14.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.3.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.24.0",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@expo/metro-config": "55.0.19",
    "@stylistic/eslint-plugin": "5.10.0",
    "@testing-library/react-native": "13.3.3",
    "@types/react": "19.2.10",
    "@vitest/coverage-v8": "4.1.5",
    "babel-preset-expo": "55.0.20",
    "eslint": "9.39.4",
    "eslint-config-expo": "55.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "react-test-renderer": "19.2.0",
    "typescript": "5.9.2",
    "typescript-language-server": "5.1.3",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "vitest-native": "0.3.0"
  },
  "private": true
}
